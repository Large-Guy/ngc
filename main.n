module program;

i32 main()
{
    f32<3> a = (0,0,0);
    
    f32<4> transform = (3, 2, 1);
    
    f32<4,4> translation = (1, 0, 0, transform.x,
                            0, 1, 0, transform.y,
                            0, 0, 1, transform.z,
                            0, 0, 0, 1);
    
    f32<,4> result =  transform as f32<,4> * translation;
    
    return result[2] as i32;
}